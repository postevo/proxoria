# ── Docker / GHCR ─────────────────────────────────────────────────────────────
GHCR_OWNER=your-github-username-or-org

# ── PostgreSQL (Docker service name = "postgres") ─────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=ai_gateway

# Database
DATABASE_URL="postgresql://postgres:change_me_strong_password@postgres:5432/ai_gateway"

# Auth (Clerk)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
GOOGLE_AI_API_KEY=xxx

# API
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_STARTER_OVERAGE_PRICE_ID=price_xxx
STRIPE_PRO_OVERAGE_PRICE_ID=price_xxx

# JWT
JWT_SECRET=change-me-in-production

# Encryption key for customer LLM provider keys (AES-256-GCM)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# Email (Resend — waitlist capture + transactional onboarding emails)
# Get your key at https://resend.com
# Webhook events to enable in Clerk dashboard: user.created, organization.created, organizationMembership.*
RESEND_API_KEY=re_xxx
RESEND_AUDIENCE_ID=xxx
# From address for transactional emails (must be verified in Resend)
EMAIL_FROM="AI Gateway <onboarding@yourdomain.com>"

# CORS — frontend origin (set to your domain in production)
CORS_ORIGIN=http://localhost:3000

# Environment
NODE_ENV=development
